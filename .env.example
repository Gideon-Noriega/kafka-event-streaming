# Kafka Broker Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SCHEMA_REGISTRY_URL=http://localhost:18081

# Producer Settings
PRODUCER_CLIENT_ID=order-producer
PRODUCER_COMPRESSION=lz4
PRODUCER_LINGER_MS=20
PRODUCER_BATCH_SIZE=65536
PRODUCER_ACKS=all
PRODUCER_MAX_IN_FLIGHT=5
PRODUCER_RETRIES=2147483647
PRODUCER_RETRY_BACKOFF_MS=100

# Consumer Settings
CONSUMER_GROUP_ID=order-processing-group
CONSUMER_AUTO_OFFSET_RESET=earliest
CONSUMER_MAX_POLL_RECORDS=500
CONSUMER_MAX_POLL_INTERVAL_MS=300000
CONSUMER_SESSION_TIMEOUT_MS=45000
CONSUMER_HEARTBEAT_INTERVAL_MS=3000

# Transaction Settings
TRANSACTION_TIMEOUT_MS=60000
TRANSACTIONAL_ID_PREFIX=order-processor

# Dead Letter Queue
DLQ_TOPIC=orders.dlq
DLQ_MAX_RETRIES=3
DLQ_RETRY_BACKOFF_MS=1000

# Application Settings
LOG_LEVEL=INFO
METRICS_PORT=9090
API_PORT=8000

# Database (for Connect)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orders
POSTGRES_USER=streaming
POSTGRES_PASSWORD=streaming_pass

# Elasticsearch (for Connect)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=orders
